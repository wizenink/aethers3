# AetherS3 production config file (TOML).
#
# Place this on each node (default path: /etc/aether_s3/config.toml, or point
# AETHER_CONFIG at it). When present, these values override the environment
# variables — env vars are the dev/default path, this file is for production.
#
# NOT set here (they are BEAM-level, needed before app config loads):
#   - node name  -> RELEASE_NODE / rel/vm.args.eex
#   - dist cookie -> RELEASE_COOKIE / ~/.erlang.cookie (mode 0400 in prod)

port = 9000
# Operational endpoints (/health, /ready, /metrics) — no auth; firewall as needed.
admin_port = 9001
data_dir = "/var/lib/aether_s3"
replication_factor = 3

# Replicas that must ack before a PUT returns: an integer, "quorum", or "all".
# Higher = more durable, less available. "quorum" survives a minority loss.
write_quorum = "quorum"

require_auth = true

# Log level: debug | info | notice | warning | error (and friends). Can also be
# changed live on a running node: bin/aether_s3 rpc 'AetherS3.Config.set_log_level("debug")'
# log_level = "info"

# Control-plane dead-member eviction (opt-in). Seconds a member must be
# unreachable before the Ra leader evicts it. Omit to disable (safe default).
# cp_evict_grace = 60

# Reap abandoned multipart uploads (opt-in). Seconds after which an upload with
# no Complete/Abort is swept (its parts + init marker deleted). The age is
# measured from initiation, so in-flight uploads are safe. Omit to disable.
# mpu_reap_age = 86400

# Reclaim crashed-write staging temps (.staging/.tmp). Seconds a temp must age
# before it's swept (always on; defaults to 3600). Raise to protect very slow
# in-flight writes.
# staging_sweep_age = 3600

# --- Security ---

# In-app TLS for the S3 API. Set BOTH to PEM file paths to serve HTTPS directly
# (no reverse proxy needed). Omit to serve plain HTTP and terminate TLS at a
# Host-PRESERVING reverse proxy (SigV4 signs the Host header — a proxy that
# rewrites Host breaks signature validation). The admin port stays HTTP.
# tls_cert = "/etc/aether_s3/tls/cert.pem"
# tls_key  = "/etc/aether_s3/tls/key.pem"

# Master key used to encrypt per-user access-key secrets at rest in the control
# plane. Required once you mint dynamic keys via the admin API. Keep it identical
# on every node and out of version control.
# master_key = "a-long-random-passphrase"

# Bootstrap bearer token for the admin identity API (POST /admin/users, etc.) on
# the admin port. Omit to disable that API entirely (recommended unless in use).
# admin_token = "a-long-random-token"

# Config-seeded root identities: always-present admin credentials so a fresh
# cluster is usable before any key is minted. Additional users + keys are created
# at runtime via the admin API and replicate through the control plane. `user`
# defaults to "root" and `admin` to true. (Also settable via env:
# AETHER_ROOT_ACCESS_KEY / AETHER_ROOT_SECRET_KEY.) The old [credentials] map is
# superseded and no longer read.
[[root_identities]]
access_key = "AKIA_ROOT"
secret_key = "change-me"
# user = "root"
# admin = true

# Cluster discovery. Pick ONE strategy:
#   "dns"    -> DNSPoll: dns_query resolves to all node IPs (containers/k8s)
#   "epmd"   -> static list of node names in `peers`
#   "gossip" -> UDP-multicast auto-discovery on the LAN (VMs, e.g. Proxmox)
# Node names must be an IP or an FQDN (dotted) — a bare short hostname is rejected.
[cluster]
strategy = "gossip"
secret = "shared-gossip-secret"        # for "gossip" (optional but recommended)
# dns_query = "aether.internal"        # for "dns"
# node_basename = "aether"             # for "dns"
# peers = ["aether@n1.lan", "aether@n2.lan", "aether@n3.lan"]   # for "epmd"
